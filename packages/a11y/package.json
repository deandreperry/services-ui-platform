{
  "name": "@services-ui/a11y",
  "version": "0.1.0",
  "description": "Reusable accessibility primitives for Services UI Platform.",
  "type": "module",
  "files": ["dist"],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.json",
    "dev": "vite build --watch",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.2.0"
  },
  "devDependencies": {
    "@services-ui/eslint-config": "workspace:*",
    "@services-ui/tsconfig": "workspace:*",
    "react": "^19.0.0"
  }
}
